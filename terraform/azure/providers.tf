terraform {
  required_version = ">= 1.5"
  required_providers {
    azurerm = {
      source  = "hashicorp/azurerm"
      version = "~> 3.100"
    }
    random = {
      source  = "hashicorp/random"
      version = "~> 3.6"
    }
  }
}

# Authentication is handled via Azure CLI (`az login`) or environment variables.
# Do NOT hardcode subscription_id here.
provider "azurerm" {
  features {}
}
